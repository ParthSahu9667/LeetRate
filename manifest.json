{
  "manifest_version": 3,
  "name": "LeetRank",
  "version": "1.0",
  "description": "Fetches and displays the clist.by rating for LeetCode problems directly on the page.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeetRank"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/problems/*",
    "https://clist.by/api/v4/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": [
        "dist/content.js"
      ]
    }
  ],
  "icons": {
    "128": "images/icon.png"
  }
}
